{
  "name": "@nhost/screenshot-extension",
  "private": true,
  "version": "0.1.0",
  "description": "Nshot — Chrome extension for composing screenshots (dim, spotlight, outline, crop) on any page.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "dev": "node dev/serve.mjs",
    "icons": "node dev/make-icons.mjs",
    "icons:watch": "node dev/make-icons.mjs --watch",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.25.0",
    "typescript": "5.8.3"
  }
}
