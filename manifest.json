{
  "manifest_version": 3,
  "name": "Nshot - Screenshot Tool",
  "version": "0.1.0",
  "description": "Compose polished screenshots — dim, spotlight, outline, and crop — on any page.",
  "minimum_chrome_version": "120",
  "permissions": ["activeTab", "scripting", "downloads", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": ["*://*/harness.html", "*://*/harness2.html"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-tool": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle Nshot on the current tab"
    },
    "freeze-ui": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Freeze the hovered UI and open Nshot in select mode"
    }
  },
  "action": {
    "default_title": "Nshot - Screenshot Tool",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
